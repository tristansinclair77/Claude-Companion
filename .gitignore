node_modules/
dist/
out/

# SQLite databases (runtime data)
*.db
*.db-shm
*.db-wal

# Debug session logs (runtime, rolling — not source)
debug-sessions/

# Logs
*.log
npm-debug.log*

# OS junk
.DS_Store
Thumbs.db
Desktop.ini

# Temp files
temp/

# Aria → Claude Code sync runtime state (generated by scripts/aria-claude-sync.py)
# The SessionStart hook regenerates these on every session — should not be tracked.
.claude/aria-context.md
.claude/aria-mode.txt

# Neural model weights (large binary, not tracked)
src/main/neural/models/*.json

# Personal reference assets (not part of repo)
ref/

# Personal music backup (Suno workspace downloads)
music/

# Text-adventure runtime state (per-character — generated at play time)
characters/*/text-adventure.json
characters/*/text-adventure-log.json
characters/*/text-adventure-side-chat.json
characters/*/text-adventure-gm-chat.json
characters/*/text-adventure-implementation-tasks.md
characters/*/text-adventure-debug-responses.json

# Text-story runtime state (each story lives in its own folder here)
stories/

# RVC server Python 3.10 venv (large, recreatable — see scripts/rvc-server/requirements.txt)
scripts/rvc-server/venv/

# Python cache
**/__pycache__/
*.pyc
*.pyo

# TTS / voice model weights (large binaries, not tracked)
# These are downloaded at runtime and can be hundreds of MB each.
*.pth
*.pt
*.ckpt
*.safetensors
*.onnx
*.bin
models/
voices/
weights/
checkpoints/
